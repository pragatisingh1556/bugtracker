# MySQL database credentials
# for local dev: use localhost/3306
# for production: use cloud MySQL credentials (Aiven, Railway, etc.)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=bugtracker

# set to "true" for cloud MySQL (SSL required), "false" for local
DB_SSL=false

# JWT secret for signing auth tokens - use a long random string in production
JWT_SECRET=bugtracker_secret_key_2025_change_me

# server port
PORT=5000
